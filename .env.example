# === Required ===
EXA_API_KEY=<exa-api-key>
ANTHROPIC_API_KEY=<llm-api-key>

# === Optional ===
# LLM model to use for curation (default: claude-sonnet-4-6-20250217)
# CURATOR_MODEL=claude-sonnet-4-6-20250217

# How many hours back to search (default: 36)
# SEARCH_WINDOW_HOURS=36

# Memory window in days (default: 14)
# MEMORY_WINDOW_DAYS=14

# Max digest items (default: 15)
# MAX_DIGEST_ITEMS=15

# Min distinct domains per event (default: 2)
# MIN_DOMAINS=2

# Output directory for generated site (default: public)
# OUTPUT_DIR=public

# Data directory for state files (default: data)
# DATA_DIR=data

# Set to "1" to skip API calls and use sample data
# DRY_RUN=0

# Secret token to protect the POST /run endpoint (Cloud Scheduler sends this)
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# RUN_SECRET=
